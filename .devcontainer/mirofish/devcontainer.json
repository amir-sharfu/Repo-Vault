{
  "name": "MiroFish Playground",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "18"
    }
  },
  "postCreateCommand": "bash /workspaces/repo-vault/.devcontainer/mirofish/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "Vue.volar",
        "ms-python.python"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteEnv": {
    "LLM_API_KEY": "${localEnv:LLM_API_KEY}",
    "LLM_BASE_URL": "${localEnv:LLM_BASE_URL}",
    "LLM_MODEL_NAME": "${localEnv:LLM_MODEL_NAME}",
    "ZEP_API_KEY": "${localEnv:ZEP_API_KEY}"
  },
  "forwardPorts": [3000, 5001],
  "portsAttributes": {
    "3000": {
      "label": "MiroFish Frontend",
      "onAutoForward": "openBrowser"
    },
    "5001": {
      "label": "MiroFish Backend",
      "onAutoForward": "notify"
    }
  }
}
